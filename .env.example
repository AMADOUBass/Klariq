# ─── Database (Neon PostgreSQL — Canadian region) ───────────────────────────
# Pooled connection (used by the app via PgBouncer)
DATABASE_URL=postgresql://user:password@ep-xxx.ca-central-1.aws.neon.tech/klariq?sslmode=require&pgbouncer=true

# Direct connection (used by Prisma migrations — bypasses PgBouncer)
DATABASE_DIRECT_URL=postgresql://user:password@ep-xxx.ca-central-1.aws.neon.tech/klariq?sslmode=require

# ─── Redis (Upstash — us-east-1 or ca-central-1) ────────────────────────────
REDIS_URL=rediss://default:password@hostname.upstash.io:6380

# ─── Better-Auth ─────────────────────────────────────────────────────────────
# Must be at least 32 characters. Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-at-least-32-characters-long

# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV=development
API_PORT=4000
WEB_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
