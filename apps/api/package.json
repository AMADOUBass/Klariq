    "@node-rs/argon2": "^2.0.0",
    "@scalar/nestjs-api-reference": "^1.1.11",
    "@t3-oss/env-core": "^0.11.1",
    "better-auth": "^1.2.5",
    "bullmq": "^5.34.6",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "csv-parse": "^6.2.1",
