{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "db:generate": {
      "dependsOn": ["^db:generate"],
      "outputs": ["src/generated/client/**"]
    },
    "db:migrate:deploy": {
      "cache": false
    },
    "auth:migrate": {
      "dependsOn": ["db:migrate:deploy"],
      "cache": false
    },
    "build": {
      "dependsOn": ["^build", "db:generate"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": [],
      "env": ["DATABASE_URL", "DATABASE_DIRECT_URL", "REDIS_URL", "NODE_ENV", "BETTER_AUTH_SECRET"]
    }
  }
}
